{
  "realm": "tenax",
  "enabled": true,
  "displayName": "Tenax Development Realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "clients": [
    {
      "clientId": "tenax-spa",
      "name": "Tenax SPA (Development)",
      "description": "Development-only public SPA client used for local OIDC Authorization Code + PKCE login.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://127.0.0.1:5173/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://127.0.0.1:5173",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "audience-tenax-web-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "tenax-web-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "tenax-web-api",
      "name": "Tenax Web API (Development)",
      "description": "Development-only client used for local JWT audience validation.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "tenax-web-api-dev-secret",
      "protocolMappers": [
        {
          "name": "audience-tenax-web-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "tenax-web-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ]
}
