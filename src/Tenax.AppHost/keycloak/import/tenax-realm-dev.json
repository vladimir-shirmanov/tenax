{
  "realm": "tenax",
  "enabled": true,
  "displayName": "Tenax Development Realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "clients": [
    {
      "clientId": "tenax-web-api",
      "name": "Tenax Web API (Development)",
      "description": "Development-only client used for local JWT audience validation.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "tenax-web-api-dev-secret",
      "protocolMappers": [
        {
          "name": "audience-tenax-web-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "tenax-web-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ]
}
